{
  "name": "pi-ochat",
  "version": "0.1.0",
  "description": "ochat workflow as a pi extension (personalities, profiles, /retry, /undo, /impersonate, /stats, double-press shortcuts)",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "pi -e ./src/index.ts"
  },
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "dependencies": {},
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.11.0"
  }
}
